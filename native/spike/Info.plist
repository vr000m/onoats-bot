<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>net.varunsingh.onoats</string>
	<key>CFBundleName</key>
	<string>Onoats</string>
	<key>CFBundleExecutable</key>
	<string>onoats-capturer</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSMinimumSystemVersion</key>
	<string>14.4</string>
	<key>LSUIElement</key>
	<true/>
	<!-- Two DISTINCT TCC services the plan requires both of. The spike confirms
	     empirically which prompt(s) actually fire for the Core Audio process-tap
	     path; both are declared so neither path can be silently denied. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>onoats records your microphone ("me") for transcription.</string>
	<key>NSAudioCaptureUsageDescription</key>
	<string>onoats records system audio ("them") for transcription.</string>
</dict>
</plist>
